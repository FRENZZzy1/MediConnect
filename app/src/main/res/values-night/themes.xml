<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Dark Mode -->
    <style name="Base.Theme.MediConnect" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Dark Theme Customization -->
        <item name="colorPrimary">@color/primary_teal</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorPrimaryContainer">@color/primary_teal_dark</item>
        <item name="colorOnPrimaryContainer">@color/primary_teal_light</item>

        <!-- Surface Colors (Dark) -->
        <item name="android:colorBackground">@color/dashboard_bg</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Error Colors -->
        <item name="colorError">@color/status_critical</item>
        <item name="colorOnError">@color/white</item>
    </style>
</resources>