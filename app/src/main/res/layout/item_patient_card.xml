<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Avatar circle -->
        <View
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_decoration"
            android:alpha="0.15"/>

        <!-- Patient info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvPatientName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patient Name"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvPatientDob"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Birthday: —"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvPatientPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact: —"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Right: date + type pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvAppointmentDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026-04-25"
                android:textColor="#0E7490"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvAppointmentType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Online"
                android:background="@drawable/bg_badge_orange"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textColor="#F59E0B"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>