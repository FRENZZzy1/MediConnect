<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7FA"
    android:fillViewport="true"
    tools:context=".Register">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── HEADER ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:background="@drawable/header_gradient">

            <View
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_marginTop="-40dp"
                android:layout_marginEnd="-40dp"
                android:background="@drawable/circle_decoration" />

            <View
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="-25dp"
                android:layout_marginStart="20dp"
                android:background="@drawable/circle_decoration" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:text="← Back"
                android:onClick="SplashAct"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                app:rippleColor="#33FFFFFF" />

            <LinearLayout
                android:id="@+id/rolePill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/btnBack"
                android:layout_marginStart="20dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/pill_white_translucent"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tvRolePillLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧑  PATIENT REGISTRATION"
                    android:textColor="#FFFFFFCC"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/rolePill"
                android:layout_marginStart="20dp"
                android:layout_marginTop="6dp"
                android:text="Create Your Profile"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:fontFamily="serif"
                android:lineSpacingMultiplier="1.1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="32dp"
                    android:layout_height="4dp"
                    android:background="@drawable/step_active" />

                <View
                    android:layout_width="22dp"
                    android:layout_height="4dp"
                    android:layout_marginStart="5dp"
                    android:background="@drawable/step_inactive" />

                <View
                    android:layout_width="22dp"
                    android:layout_height="4dp"
                    android:layout_marginStart="5dp"
                    android:background="@drawable/step_inactive" />

            </LinearLayout>

        </RelativeLayout>

        <!-- ── FORM AREA ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ══ ROLE TOGGLE CARD ══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12"
                        android:text="I AM REGISTERING AS"
                        android:textColor="#6B8CAE"
                        android:textSize="10sp" />
                    <!--android:background="@drawable/toggle_bg"-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="4dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRolePatient"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="🧑  Patient"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            app:backgroundTint="#0891B2"
                            app:cornerRadius="12dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRoleDoctor"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="👨‍⚕️  Doctor"
                            android:textColor="#0891B2"
                            android:textSize="13sp"
                            app:backgroundTint="#E0F2F8"
                            app:cornerRadius="12dp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ MAIN FORM CARD ══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- PERSONAL INFO -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12"
                        android:text="PERSONAL INFORMATION"
                        android:textColor="#6B8CAE"
                        android:textSize="10sp" />

                    <!-- First Name + Last Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="5dp"
                            android:layout_weight="1"
                            android:hint="First Name"
                            app:boxBackgroundColor="#F0F7FA"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxStrokeColor="#0891B2"
                            app:hintTextColor="#0891B2">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etFirstName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:layout_weight="1"
                            android:hint="Last Name"
                            app:boxBackgroundColor="#F0F7FA"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxStrokeColor="#0891B2"
                            app:hintTextColor="#0891B2">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLastName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Email Address"
                        app:boxBackgroundColor="#F0F7FA"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#0891B2"
                        app:hintTextColor="#0891B2"
                        app:startIconDrawable="@android:drawable/ic_dialog_email"
                        app:startIconTint="#0891B2">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Phone -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Mobile Number"
                        app:boxBackgroundColor="#F0F7FA"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#0891B2"
                        app:hintTextColor="#0891B2"
                        app:startIconDrawable="@android:drawable/ic_menu_call"
                        app:startIconTint="#0891B2">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Password"
                        app:boxBackgroundColor="#F0F7FA"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#0891B2"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#0891B2"
                        app:hintTextColor="#0891B2"
                        app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                        app:startIconTint="#0891B2">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Date of Birth (patient only) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDOB"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Date of Birth"
                        app:boxBackgroundColor="#F0F7FA"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#0891B2"
                        app:hintTextColor="#0891B2"
                        app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                        app:startIconTint="#0891B2">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDOB"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="false"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Sex Dropdown (patient only) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilSex"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Sex Assigned at Birth"
                        app:boxBackgroundColor="#F0F7FA"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#0891B2"
                        app:hintTextColor="#0891B2"
                        app:startIconDrawable="@android:drawable/ic_menu_info_details"
                        app:startIconTint="#0891B2">

                        <AutoCompleteTextView
                            android:id="@+id/spinnerSex"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ══ DOCTOR-ONLY FIELDS ══ -->
                    <LinearLayout
                        android:id="@+id/layoutDoctorFields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="18dp"
                            android:background="#E0EEF5" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.12"
                            android:text="PROFESSIONAL INFORMATION"
                            android:textColor="#6B8CAE"
                            android:textSize="10sp" />

                        <!-- PRC License Number -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="PRC License Number"
                            app:boxBackgroundColor="#F0F7FA"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxStrokeColor="#0891B2"
                            app:hintTextColor="#0891B2"
                            app:startIconDrawable="@android:drawable/ic_menu_agenda"
                            app:startIconTint="#0891B2">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPrcLicense"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapCharacters"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Specialization -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Specialization"
                            app:boxBackgroundColor="#F0F7FA"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxStrokeColor="#0891B2"
                            app:hintTextColor="#0891B2"
                            app:startIconDrawable="@android:drawable/ic_menu_info_details"
                            app:startIconTint="#0891B2">

                            <AutoCompleteTextView
                                android:id="@+id/spinnerSpecialization"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Clinic Name -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Clinic / Hospital Name"
                            app:boxBackgroundColor="#F0F7FA"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxStrokeColor="#0891B2"
                            app:hintTextColor="#0891B2"
                            app:startIconDrawable="@android:drawable/ic_menu_mapmode"
                            app:startIconTint="#0891B2">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etClinicName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Location -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Clinic Address / Location"
                            app:boxBackgroundColor="#F0F7FA"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxStrokeColor="#0891B2"
                            app:hintTextColor="#0891B2"
                            app:startIconDrawable="@android:drawable/ic_dialog_map"
                            app:startIconTint="#0891B2">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLocation"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapSentences"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Available Days -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Available Days"
                            app:boxBackgroundColor="#F0F7FA"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxStrokeColor="#0891B2"
                            app:hintTextColor="#0891B2"
                            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                            app:startIconTint="#0891B2">

                            <AutoCompleteTextView
                                android:id="@+id/spinnerAvailableDays"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Consultation Hours -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Consultation Hours (e.g. 9:00 AM – 5:00 PM)"
                            app:boxBackgroundColor="#F0F7FA"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxStrokeColor="#0891B2"
                            app:hintTextColor="#0891B2"
                            app:startIconDrawable="@android:drawable/ic_menu_recent_history"
                            app:startIconTint="#0891B2">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etConsultationHours"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapSentences"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Consultation Fee -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:hint="Consultation Fee (PHP)"
                            app:boxBackgroundColor="#F0F7FA"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxStrokeColor="#0891B2"
                            app:hintTextColor="#0891B2"
                            app:prefixText="₱ "
                            app:prefixTextColor="#0891B2">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etConsultationFee"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                    <!-- ── END DOCTOR FIELDS ── -->

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── PRIVACY NOTE ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#F0FDF4"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#1A10B981"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="Secure &amp; Private"
                            android:textColor="#065F46"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:lineSpacingMultiplier="1.3"
                            android:text="Your data is encrypted and protected under the Data Privacy Act of 2012."
                            android:textColor="#047857"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── CREATE ACCOUNT BUTTON ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="10dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:text="Create Account →"
                android:textSize="15sp"
                app:backgroundTint="#0891B2"
                app:cornerRadius="16dp" />

            <!-- Sign In link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? "
                    android:textColor="#6B8CAE"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvSignIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="sans-serif-medium"
                    android:text="Sign In"
                    android:textColor="#0891B2"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>